DTSTAMP:20260720T105829Z
DTSTART;VALUE=DATE:20260907
DTEND;VALUE=DATE:20260908
SUMMARY:Labor Day
DESCRIPTION:A public holiday. City offices are closed\, no hearings sit a
 nd alternate side parking is suspended.
CATEGORIES:holidays
END:VEVENT
